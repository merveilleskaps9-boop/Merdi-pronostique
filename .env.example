# ============================================================
# FOOTBALL PRONOSTICS - Configuration
# Copiez ce fichier en .env et remplissez vos cles
# ============================================================

# --- API-Football (RapidAPI) ---
# Inscription gratuite : https://rapidapi.com/api-sports/api/api-football
# Plan Free : 100 requetes/jour
API_FOOTBALL_KEY=votre_cle_ici

# --- The Odds API ---
# Inscription gratuite : https://the-odds-api.com
# Plan Free : 500 requetes/mois
ODDS_API_KEY=votre_cle_ici

# --- Anthropic Claude API ---
# Disponible via votre compte Claude.ai Pro
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=votre_cle_ici

# --- Serveur ---
PORT=3000

# --- Timezone ---
TZ=America/Toronto
